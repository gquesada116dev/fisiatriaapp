# --- App auth (single-user) ---
APP_PASSWORD=change-me-to-something-strong
AUTH_COOKIE_SECRET=generate-a-random-32-byte-string

# --- Firebase ---
# Paste the full JSON content of your service account key (one line, no newlines).
# Download it from: Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
# Your Firebase Storage bucket name (shown in Firebase Console → Storage)
FIREBASE_STORAGE_BUCKET=fisiatria-bb93f.firebasestorage.app

# --- Cloudflare R2 (audio hosting) ---
# Account ID visible in the R2 dashboard URL: dash.cloudflare.com/ACCOUNT_ID/r2
R2_ACCOUNT_ID=your-cloudflare-account-id
# Create an R2 API token with Object Read & Write permissions
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
# Name of the R2 bucket (create it in the Cloudflare dashboard, enable public access)
R2_BUCKET=fisiaprep-audio
# Public base URL of the bucket — enable "Public R2.dev Subdomain" in bucket settings
# It looks like: https://pub-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.dev
R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-...

# --- ElevenLabs ---
ELEVENLABS_API_KEY=...
# Two distinct Spanish-speaking voices for the 2-voice podcast format.
# Find voice IDs in your ElevenLabs dashboard. Defaults below are placeholders.
ELEVENLABS_VOICE_HOST_A=voice-id-for-doctor-a
ELEVENLABS_VOICE_HOST_B=voice-id-for-doctor-b
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
